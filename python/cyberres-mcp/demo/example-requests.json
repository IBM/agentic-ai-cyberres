{
  "vm_validation_basic": {
    "description": "Basic VM health check with default acceptance criteria",
    "resourceType": "vm",
    "target": {
      "hostname": "vm-prod-01.example.com",
      "ip": "10.0.1.5",
      "os": "linux"
    },
    "acceptance": {
      "fs_max_pct": 85,
      "mem_min_free_pct": 10,
      "required_services": ["sshd.service"]
    },
    "safeMode": true
  },
  "vm_validation_with_services": {
    "description": "VM validation with specific service requirements",
    "resourceType": "vm",
    "target": {
      "hostname": "web-server-01.example.com",
      "ip": "10.0.1.10",
      "os": "linux"
    },
    "acceptance": {
      "fs_max_pct": 80,
      "mem_min_free_pct": 15,
      "required_services": [
        "sshd.service",
        "nginx.service",
        "postgresql.service"
      ]
    },
    "safeMode": true
  },
  "oracle_validation_basic": {
    "description": "Oracle database connectivity and basic health check",
    "resourceType": "oracle",
    "oracle": {
      "dsn": "10.0.2.20/ORCLCDB",
      "user": "system",
      "password": "oracle123"
    },
    "acceptance": {
      "tablespace_min_free_pct": 15,
      "require_connect": true
    },
    "safeMode": true
  },
  "oracle_validation_with_host": {
    "description": "Oracle validation using discrete host/port/service",
    "resourceType": "oracle",
    "oracle": {
      "host": "oracle-prod.example.com",
      "port": 1521,
      "service": "ORCLCDB",
      "user": "system",
      "password": "oracle123"
    },
    "acceptance": {
      "tablespace_min_free_pct": 20,
      "require_connect": true
    },
    "safeMode": true
  },
  "mongodb_validation_basic": {
    "description": "MongoDB connectivity check",
    "resourceType": "mongo",
    "mongo": {
      "uri": "mongodb://admin:mongo123@10.0.2.30:27017/admin"
    },
    "acceptance": {
      "require_connect": true
    },
    "safeMode": true
  },
  "mongodb_validation_replica_set": {
    "description": "MongoDB replica set validation",
    "resourceType": "mongo",
    "mongo": {
      "uri": "mongodb://admin:mongo123@mongo-rs-01.example.com:27017,mongo-rs-02.example.com:27017,mongo-rs-03.example.com:27017/admin?replicaSet=rs0"
    },
    "acceptance": {
      "require_connect": true,
      "replication": {
        "allowed_states": [1, 2]
      }
    },
    "safeMode": true
  },
  "mongodb_validation_discrete": {
    "description": "MongoDB validation using discrete parameters",
    "resourceType": "mongo",
    "mongo": {
      "host": "mongo-prod.example.com",
      "port": 27017,
      "user": "admin",
      "password": "mongo123",
      "database": "admin"
    },
    "acceptance": {
      "require_connect": true
    },
    "safeMode": true
  },
  "oracle_discover_config_basic": {
    "description": "Discover Oracle configuration with service name",
    "tool": "db_oracle_discover_config",
    "parameters": {
      "host": "oracle-prod.example.com",
      "user": "system",
      "password": "oracle123",
      "service": "ORCL"
    }
  },
  "oracle_discover_config_with_sid": {
    "description": "Discover Oracle configuration using SID",
    "tool": "db_oracle_discover_config",
    "parameters": {
      "host": "192.168.1.100",
      "user": "sys",
      "password": "syspass456",
      "port": 1521,
      "sid": "ORCL"
    }
  },
  "oracle_discover_config_auto": {
    "description": "Auto-discover Oracle configuration (tries common service names)",
    "tool": "db_oracle_discover_config",
    "parameters": {
      "host": "oracle-dev.local",
      "user": "system",
      "password": "devpass789"
    }
  },
  "oracle_discover_config_custom_port": {
    "description": "Discover Oracle configuration on non-standard port",
    "tool": "db_oracle_discover_config",
    "parameters": {
      "host": "oracle-test.example.com",
      "user": "system",
      "password": "testpass321",
      "port": 1522,
      "service": "TESTDB"
    }
  }
}