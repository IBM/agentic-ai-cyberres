# Environment configuration for MCP recovery validation prototype

# Host interface to bind the MCP server. Defaults to 0.0.0.0
MCP_HOST=0.0.0.0

# Port for the MCP server. Defaults to 8000
MCP_PORT=8000

# Transport used by FastMCP. Defaults to streamable-http
MCP_TRANSPORT=streamable-http

# Path to a JSON file containing secrets (unused in prototype)
SECRETS_FILE=secrets.json

# SSH host-key verification (recommended defaults)
SSH_STRICT_HOST_KEY_CHECKING=true
SSH_TRUST_UNKNOWN_HOSTS=false
# Optional explicit known_hosts file path
# SSH_KNOWN_HOSTS_FILE=/Users/you/.ssh/known_hosts
