# Recovery Validation Agent Configuration

# =============================================================================
# MCP Server Configuration
# =============================================================================
MCP_SERVER_URL=http://localhost:8000/mcp

# =============================================================================
# SSH Credentials (for VM validation)
# =============================================================================
# Global SSH credentials (used if host-specific not provided)
SSH_USER=admin
SSH_PASSWORD=
SSH_KEY_PATH=/path/to/ssh/key.pem

# Host-specific SSH credentials (optional)
# Format: SSH_<HOST_WITH_UNDERSCORES>_USER
# Example: SSH_192_168_1_100_USER=vmadmin
# SSH_192_168_1_100_PASSWORD=vmpassword

# =============================================================================
# Oracle Database Credentials
# =============================================================================
# Global Oracle credentials
ORACLE_USER=system
ORACLE_PASSWORD=oracle_password
ORACLE_SERVICE=ORCL
ORACLE_PORT=1521

# Oracle configuration paths (for discovery)
ORACLE_LISTENER_ORA=/u01/app/oracle/product/19c/network/admin/listener.ora
ORACLE_TNSNAMES_ORA=/u01/app/oracle/product/19c/network/admin/tnsnames.ora

# Host-specific Oracle credentials (optional)
# ORACLE_192_168_1_200_USER=sysadmin
# ORACLE_192_168_1_200_PASSWORD=dbpassword

# =============================================================================
# MongoDB Credentials
# =============================================================================
# Global MongoDB credentials
MONGO_USER=admin
MONGO_PASSWORD=mongo_password
MONGO_AUTH_DB=admin
MONGO_PORT=27017

# Host-specific MongoDB credentials (optional)
# MONGO_192_168_1_300_USER=mongoadmin
# MONGO_192_168_1_300_PASSWORD=mongopassword

# =============================================================================
# Email Configuration
# =============================================================================
# Default email recipient for validation reports (optional)
# If not set, user will be prompted to provide email address
USER_EMAIL=admin@example.com

# SMTP server configuration for sending email reports
SMTP_SERVER=localhost
SMTP_PORT=25
EMAIL_FROM=recovery-validation@cyberres.com

# For authenticated SMTP (SendGrid, Gmail, Office365, etc.)
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# SendGrid Configuration Example:
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your_sendgrid_api_key_here
# SMTP_USE_TLS=true
# EMAIL_FROM=noreply@yourdomain.com

# Gmail Configuration Example:
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_USE_TLS=true

# Office 365 Configuration Example:
# SMTP_SERVER=smtp.office365.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@company.com
# SMTP_PASSWORD=your_password
# SMTP_USE_TLS=true

# Note: Email can also be provided at runtime via:
# - Natural language prompt: "...send report to user@example.com"
# - CLI flag: --email user@example.com
# - Interactive prompt when running the agent

# =============================================================================
# LLM Configuration (for PydanticAI conversation)
# =============================================================================
# Choose one: openai, groq, ollama, azure, vertexai
LLM_BACKEND=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Groq Configuration (alternative)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-70b-versatile

# Ollama Configuration (local, alternative)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Azure OpenAI Configuration (alternative)
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_MODEL=gpt-4o-mini

# Vertex AI Configuration (alternative)
# VERTEXAI_PROJECT=your-gcp-project
# VERTEXAI_LOCATION=us-central1
# VERTEXAI_MODEL=gemini-1.5-flash-001

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=recovery_validation.log

# =============================================================================
# Validation Configuration
# =============================================================================
# Default timeout for MCP tool calls (seconds)
MCP_TIMEOUT=30

# Stop validation on first failure
STOP_ON_FAILURE=false

# Auto-discover resources by default
AUTO_DISCOVER=true

# Send email reports by default
SEND_EMAIL=true